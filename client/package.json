{
  "name": "scpca-portal-root",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@3.6.3",
  "workspaces": [
    "app",
    ".storybook"
  ],
  "scripts": {
    "dev": "yarn workspace scpca-portal-app dev",
    "build": "yarn workspace scpca-portal-app build",
    "storybook": "yarn workspace scpca-portal-storybook storybook",
    "storybook:build": "yarn workspace scpca-portal-storybook storybook:build",
    "start": "next start",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6"
  }
}
